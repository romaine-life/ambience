# Shell scripts must stay LF — autocrlf would otherwise hand Git Bash CRLF
# files, which fail to parse (`$'\r': command not found`).
*.sh text eol=lf

.github/** text eol=lf
chart/** text eol=lf
docs/agentic-issue-flow.md text eol=lf
k8s/** text eol=lf
mcp/** text eol=lf
scripts/agent/** text eol=lf

# Binary chrome assets — never apply text/EOL normalization.
cmd/ambience/web/fonts/*.ttf binary
